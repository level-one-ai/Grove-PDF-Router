# ============================================================
# MICROSOFT GRAPH API / AZURE AD / ONEDRIVE
# ============================================================
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
ONEDRIVE_USER_ID=your-onedrive-user-id-here

# The OneDrive folder paths
ONEDRIVE_WATCH_FOLDER=/drive/root:/Grove Group Scotland/Grove Bedding/Scans
ONEDRIVE_PROCESSED_FOLDER=/drive/root:/Grove Group Scotland/Grove Bedding/Scans/Processed

# ============================================================
# FIREBASE
# ============================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================================
# GOOGLE DRIVE
# ============================================================
GOOGLE_CLIENT_EMAIL=your-google-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-root-folder-id

# ============================================================
# MAKE.COM
# ============================================================
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id-here

# ============================================================
# APP
# ============================================================
# Your Vercel deployment URL (no trailing slash)
WEBHOOK_NOTIFICATION_URL=https://your-project.vercel.app

# Secret to validate incoming callbacks from Make.com
CALLBACK_SECRET=generate-a-random-string-here
